# ===========================================
# SERVER
# ===========================================
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ===========================================
# GOOGLE SHEETS (the database)
# ===========================================
# The spreadsheet ID is the long string in the sheet URL between /d/ and /edit
# e.g. https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=1FuvgHnycrGXrBKKRAhuWnHn4Fm37aN_waLwHJl-F2hI

# Tab (sheet) names inside that spreadsheet. Created automatically on first run if missing.
SHEET_TAB_LEADS=Leads
SHEET_TAB_TIMELINE=Timeline
SHEET_TAB_NEED_ATTENTION=NeedAttention
SHEET_TAB_USERS=Users
SHEET_TAB_SETTINGS=Settings
SHEET_TAB_PUSH_SUBSCRIPTIONS=PushSubscriptions

# Service account credentials (from Google Cloud Console -> IAM -> Service Accounts -> Keys)
# Paste the values from the downloaded JSON key file. Keep the \n in the private key literal.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ===========================================
# FIREBASE ADMIN (auth verification)
# ===========================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Email of the very first admin (auto-seeded into the Users tab on first boot if Users tab is empty)
SEED_ADMIN_EMAIL=admin@youwegroup.com
SEED_ADMIN_NAME=Admin

# ===========================================
# PUSH NOTIFICATIONS (Web Push / VAPID)
# ===========================================
# Generate once with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# This is just a self-signed keypair for this app - not tied to any external account.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@youwegroup.com
