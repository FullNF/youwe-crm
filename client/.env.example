# Cloudinary - used ONLY for optional photo attachments on manual "Send Custom
# Notification" messages (Settings page). Free, no credit card needed.
# Cloud Name: shown on your Cloudinary dashboard homepage.
# Upload Preset: Settings -> Upload -> Upload presets -> Add upload preset -> Signing Mode: Unsigned
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
